# Remove.bg API Key
# Get your free API key at: https://www.remove.bg/api
# Free tier: 50 credits/month
REMOVEBG_API_KEY=your_api_key_here

# Google OAuth (server-side only; never expose the secret in the browser)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
# Generate a long random string, e.g. `openssl rand -base64 32`
SESSION_SECRET=replace_with_a_long_random_secret

# Cloudflare (optional, for deployment scripts)
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
